# game/sakuracan.rpy:552
translate french omegaxui_394f7b7b:

    # r "Come with me to the other room, it's time to relax a bit."
    r "Viens avec moi dans l'autre pièce, il est temps de se détendre un peu."

# game/sakuracan.rpy:560
translate french omegaxui_186c4c10:

    # r "Do you see this room, Hinata? From now on, we’ll spend every evening here."
    r "Tu vois cette pièce, Hinata ? Désormais de maintenant, nous passerons tous les soirs ici."

# game/sakuracan.rpy:561
