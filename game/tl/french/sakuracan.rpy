    # r "Wow... Look at you! You're just perfect in it."
    r "Wow... Regardez-vous ! Vous êtes juste parfait."

# game/sakuracan.rpy:537
translate french omegaxui_c2466ce5:

    # hi "The outfit is so... Revealing... Do you like how it highlights my shapes?"
    hi "La tenue est donc ... Révéler ... Aimez-vous comment il met en évidence mes formes ?"

# game/sakuracan.rpy:542
translate french omegaxui_5b109283:

    # r "Of course, Hinata... You're incredibly hot."
    r "Bien sûr, Hinata... Vous êtes incroyablement chaud."

# game/sakuracan.rpy:547
translate french omegaxui_4de84177:

    # hi "Thank you... You making me feel so flustered..."
