    # r "Let's slowly discover everything we can..."
    r "Voyons lentement tout ce que nous pouvons ..."

# game/sakuracan.rpy:566
translate french omegaxui_def6ee62:

    # hi "Y-yes..."
    hi "O-oui..."

# game/sakuracan.rpy:567
translate french omegaxui_6a1ce48e:

    # hi "I'm ready..."
    hi "Je suis prêt..."

# game/sakuracan.rpy:571
translate french omegaxui_e821e54e:

    # r "What shall we name this room? Love room? Lust room? Training room? M...? What do you think?"
    r "Comment nommerons-nous cette salle ? Vous aimez la salle ? Besoin de la salle ? Salle d'entraînement ? M... ? Que pensez-vous ?"

# game/sakuracan.rpy:575
translate french omegaxui_b60c5c89:

    # hi "The last one... Sounds so hot... I like it..."
    hi "Le dernier ... Ça sonne si chaud ... J'aime ça ..."

# game/sakuracan.rpy:579
translate french omegaxui_6a4e9543:

    # r "Training room. So be it."
    r "Salle d'entraînement. Soit."

# game/sakuracan.rpy:580
translate french omegaxui_32378ce2:

    # r "So in this room you are mine and I am yours. No prying eyes, no judgment or fear."
    r "Donc, dans cette pièce, vous êtes à moi et je suis à vous. Pas de regard, pas de jugement ou de peur."

# game/sakuracan.rpy:581
translate french omegaxui_4c218dae:

    # r "No matter what you and I do in this room... All of this will remain within these walls..."
    r "Peu importe ce que vous et moi faisons dans cette pièce ... Tout cela restera à l'intérieur de ces murs ..."

# game/sakuracan.rpy:585
translate french omegaxui_f97e2160:

    # hi "Yes... Only here..."
    hi "Oui... Seulement ici..."

# game/sakuracan.rpy:589
translate french omegaxui_7d6dae57:

    # r "In ordinary life, anywhere, we are good friends... Lovers..."
    r "Dans la vie ordinaire, n'importe où, nous sommes de bons amis ... Couvertures ..."

# game/sakuracan.rpy:590
translate french omegaxui_fec489c0:

    # r "But when you cross the threshold of this room... You are my submissive, my slave, I am your master, owner."
    r "Mais quand tu franchis le seuil de cette pièce... Tu es ma soumise, mon esclave, je suis ton maître, ton possesseur."

# game/sakuracan.rpy:594
translate french omegaxui_ec718e7f:

    # hi "T-Then... Take care of me... Master..."
    hi "T-Alors ... Prends soin de moi ... Maître ..."

# game/sakuracan.rpy:611
