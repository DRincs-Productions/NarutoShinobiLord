    hi "Forse lo farò! Vedi!"

# game/sakuracan.rpy:3118
translate italian positrenas_7c9d9337:

    # r "Good night."
    r "Buona notte."

# game/sakuracan.rpy:3124
translate italian positrenas_78e6f09b:

    # m "Hinata left. I need to do something with this new information..."
    m "Hinata sinistra. Devo fare qualcosa con questa nuova informazione..."

# game/sakuracan.rpy:3125
translate italian positrenas_acad18b8:

    # m "Where the hell is Kamiko?"
    m "Dove l'inferno è Kamiko?"

# game/sakuracan.rpy:3126
translate italian positrenas_1246dd58:

    # m "She hasn't swung by the apartment for a long time..."
    m "Non ha oscillato dall'appartamento per molto tempo..."

# game/sakuracan.rpy:3127
translate italian positrenas_d15bf6d9:

    # m "How can I find her?"
    m "Come la trovo?"

# game/sakuracan.rpy:3128
translate italian positrenas_0da678aa:

    # m "I feel that we are connected more than usual... I noticed this after the coma..."
    m "Mi sento che siamo collegati più del solito... lo ho notato dopo il coma..."

# game/sakuracan.rpy:3129
translate italian positrenas_6e58da17:

    # m "Perhaps a new ability could help me out?"
    m "Forse una nuova abilità potrebbe aiutarmi?"

# game/sakuracan.rpy:3145
translate italian sascixd_3394fc84:

    # m "What is this? Chakra? Traces are everywhere..."
    m "Cos'è questo? Chakra? Le tracce sono ovunque..."

# game/sakuracan.rpy:3146
translate italian sascixd_8e4c1c09:

    # m "I can clearly tell that this is Kamiko's chakra, I can feel it for some reason."
    m "Posso dire chiaramente che questo è il chakra di Kamiko, posso sentirlo per qualche ragione."

# game/sakuracan.rpy:3147
translate italian sascixd_e8245bb1:

    # m "I think I got it, this trail will lead me to Kamiko."
    m "Penso che l'ho ottenuta, questo sentiero mi condurrà a Kamiko."

# game/sakuracan.rpy:3148
translate italian sascixd_c11a53b5:

    # m "These eyes are a handy thing, huh."
    m "Questi occhi sono una cosa utile, ehh."

# game/sakuracan.rpy:3162
translate italian sascixd_cac54518:

    # m "Is that Kamiko there? That's definitely her."
    m "È Kamiko lì? È sicuramente lei."

# game/sakuracan.rpy:3163
translate italian sascixd_58a7ac5b:

    # m "What is she doing there?"
    m "Che cosa sta facendo lì?"

# game/sakuracan.rpy:3171
translate italian sascixd_2e0a48d1:

    # ka "Sweetie, I see you."
    ka "Sweetie, ti vedo."

# game/sakuracan.rpy:3175
translate italian sascixd_5cef1859:

    # r "Oh... Hello."
    r "Oh... Hello."

# game/sakuracan.rpy:3180
translate italian sascixd_965d0580:

    # ka "What a sudden visit. How did you even find me?"
    ka "Che visita improvvisa. Come mi hai trovato?"

# game/sakuracan.rpy:3185
translate italian sascixd_92c11193:

    # r "New eyes, I saw a trace of your chakra."
    r "Nuovi occhi, ho visto una traccia del tuo chakra."

# game/sakuracan.rpy:3190
translate italian sascixd_287f9455:

    # ka "Oh, so you were able to keep track? Not bad, even Uchiha with his Sharingan failed."
    ka "Oh, quindi sei stato in grado di tenere la traccia? Non male, nemmeno Uchiha con il suo Sharingan fallito."

# game/sakuracan.rpy:3195
translate italian sascixd_5c072834:

    # r "Am I disturbing you?"
    r "Ti disturbo?"

# game/sakuracan.rpy:3200
translate italian sascixd_4793aa32:

    # ka "Not at all, I've already finished the ritual."
    ka "Niente affatto, ho già finito il rituale."

# game/sakuracan.rpy:3205
translate italian sascixd_ee873055:

    # r "Ritual? What are you talking about?"
    r "Rituale? Di cosa stai parlando?"

# game/sakuracan.rpy:3210
translate italian sascixd_18ea5907:

    # ka "Summoning a new pawn, I've already done this with you."
    ka "Evocando una nuova pedina, l'ho già fatto con te."

# game/sakuracan.rpy:3215
translate italian sascixd_b107cc5d:

    # r "Are you summoning someone else? Did you succeed?"
    r "Stai evocando qualcun altro? Sei riuscito?"

# game/sakuracan.rpy:3220
translate italian sascixd_e9ed558e:

    # ka "Well, how can I put this... You can take a look for yourself."
    ka "Beh, come posso mettere questo... Puoi dare un'occhiata a te stesso."

# game/sakuracan.rpy:3229
translate italian sascixd_c85c7b6d:

    # r "Fuck... My god... What evenis it!?"
    r "Fuck... Il mio dio... Che cos'è!?"

# game/sakuracan.rpy:3231
translate italian sascixd_3dba32fc:

    # ka "The body, as you can see. She couldn't stand it."
    ka "Il corpo, come puoi vedere. Non riusciva a sopportarlo."

# game/sakuracan.rpy:3233
translate italian sascixd_49ea6bfc:

    # r "Couldn't stand what? What did you do to her?"
    r "Non riesce a sopportare cosa? Cosa le hai fatto?"

# game/sakuracan.rpy:3235
translate italian sascixd_59a8620b:

    # ka "The transfer. Her body couldn't handle the interdimensional travel."
    ka "Il trasferimento. Il suo corpo non riusciva a gestire il viaggio interdimensionale."

# game/sakuracan.rpy:3237
translate italian sascixd_d4baaf8b:

    # r "I... I could end up like that too?"
    r "Io... Potrei finire anche così?"

# game/sakuracan.rpy:3239
translate italian sascixd_6526f2ac:

    # ka "Of course, dear, before you I called about a hundred applicants who could not stand the transfer."
    ka "Naturalmente, caro, prima di voi ho chiamato circa un centinaio di candidati che non potevano sopportare il trasferimento."

# game/sakuracan.rpy:3241
translate italian sascixd_ffdad8bc:

    # r "This... It’s not sitting in my head right..."
    r "Questo... Non è seduto nella mia testa a destra..."

# game/sakuracan.rpy:3243
translate italian sascixd_d576e389:

    # ka "You are special, I already said it... Special not only because you survived the transfer, you are very useful, I would get rid of useless pawns right away, but this is not about you."
    ka "Sei speciale, l'ho già detto... Speciale non solo perché sei sopravvissuto al trasferimento, sei molto utile, Mi sbarazzerei di pedine inutili, ma non è su di voi."

# game/sakuracan.rpy:3245
translate italian sascixd_3ebea423:

    # r "So... You're going to summon someone else?"
    r "So... Stai per convocare qualcun altro?"

# game/sakuracan.rpy:3247
translate italian sascixd_60b7880f:

    # ka "Yes... I feel like I'm close to summoning another pawn."
    ka "Sì... Mi sento come se fossi vicino a chiamare un'altra pedina."

# game/sakuracan.rpy:3249
translate italian sascixd_662abe82:

    # r "Which attempt is this? How many people failed?"
    r "Quale tentativo è questo? Quante persone sono fallite?"

# game/sakuracan.rpy:3251
translate italian sascixd_7142279f:

    # ka "This time it's more difficult... This poor thing was... Hmm... 274."
    ka "Questa volta è più difficile... Questa povera cosa era... Hmm... 274."

# game/sakuracan.rpy:3253
translate italian sascixd_8168cea9:

    # m "God... she killed so many people..."
    m "Dio... uccise così tante persone..."

# game/sakuracan.rpy:3254
translate italian sascixd_da1eb514:

    # m "I don't know what to think..."
    m "Non so cosa pensare..."

# game/sakuracan.rpy:3255
translate italian sascixd_2f13a6a8:

    # m "I have only one goal here, I have to tell her... that I..."
    m "Ho un solo obiettivo qui, devo dirle... che io..."

# game/sakuracan.rpy:3267
translate italian razkazatey_e3904bb5:

    # m "I'll do it... It's too dangerous... I have no choice."
    m "lo farò... è troppo pericoloso... non ho scelta."

# game/sakuracan.rpy:3271
translate italian nerazkazal_8237d0c5:

    # m "No... After what I saw... I have to do everything on my own..."
    m "No... Dopo quello che ho visto... devo fare tutto da solo..."

translate italian strings:

    # game/sakuracan.rpy:199
    old "I think I'm pretty good at medicine, although I have no formal education."
    new "Penso di essere abbastanza bravo in medicina, anche se non ho un'istruzione formale."

    # game/sakuracan.rpy:199
    old "To be honest, I'm still an amateur, but I like to help people."
    new "Per essere onesti, sono ancora un dilettante, ma mi piace aiutare le persone."

    # game/sakuracan.rpy:239
    old "I'm a great talker, sometimes a good conversation heals better than medicine."
    new "Sono un grande parlatore, a volte una buona conversazione guarisce meglio della medicina."

    # game/sakuracan.rpy:239
    old "I prefer to be silent, it helps me concentrate on work."
    new "Preferisco tacere, mi aiuta a concentrarmi sul lavoro."

    # game/sakuracan.rpy:1042
    old "Follow him, I should know."
    new "Lo segua, lo dovrei sapere."

    # game/sakuracan.rpy:1042
    old "I’m leaving, it’s getting too scary."
    new "Sto partendo, sta diventando troppo spaventoso."

    # game/sakuracan.rpy:3257
    old "Tell her about the murderer and rebirth."
    new "Le parli dell'assassino e della rinascita."

    # game/sakuracan.rpy:3257
    old "Don’t tell her, figure it out yourself."
    new "Non dirglielo, capiscila te stesso."

